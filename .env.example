# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/syllabus_chatbot

# Model config (swap to sonnet for better accuracy)
CHAT_MODEL=claude-haiku-4-5-20251001
PREPROCESSING_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small

# App config
APP_ENV=development
LOG_LEVEL=INFO
